{
  "name": "kuritterweight-line-bot",
  "type": "module",
  "scripts": {
    "dev": "$npm_execpath run build:mcp-app && vite",
    "build:mcp-app": "vite build -c vite.mcp-app.config.ts",
    "build": "$npm_execpath run build:mcp-app && vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@line/bot-sdk": "^11.1.0",
    "@modelcontextprotocol/ext-apps": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chart.js": "^4.5.1",
    "hono": "^4.12.23",
    "hono-rate-limiter": "^0.5.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@cloudflare/workers-types": "^4.20260404.1",
    "prettier": "^3.8.1",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.2",
    "vite-ssr-components": "^0.6.1",
    "wrangler": "^4.97.0"
  }
}
